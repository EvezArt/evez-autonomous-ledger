{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EVEZ System Pulse",
  "description": "Live runtime state of the EVEZ autonomous system — updated by reconciler every 15 min",
  "type": "object",
  "required": ["timestamp", "epoch", "phi", "agents_active", "sensory", "cognition", "trajectory", "latency_mode"],
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "epoch": { "type": "integer", "description": "Monotonically increasing pulse count since genesis" },
    "phi": { "type": "number", "description": "Current IIT-proxy consciousness score" },
    "phi_delta": { "type": "number", "description": "Change in phi since last pulse" },
    "phi_level": { "type": "string", "enum": ["AWAKENING", "CONSCIOUS", "AWARE", "TRANSCENDENT"] },
    "agents_active": { "type": "integer" },
    "workflows_active": { "type": "integer" },
    "decisions_total": { "type": "integer" },
    "sensory": {
      "type": "object",
      "properties": {
        "last_web_perception": { "type": "string", "format": "date-time" },
        "last_github_perception": { "type": "string", "format": "date-time" },
        "last_market_perception": { "type": "string", "format": "date-time" },
        "last_temporal_scan": { "type": "string", "format": "date-time" },
        "sources_active": { "type": "integer" },
        "top_signal": { "type": "string" }
      }
    },
    "cognition": {
      "type": "object",
      "properties": {
        "last_synthesis": { "type": "string", "format": "date-time" },
        "last_dream": { "type": "string", "format": "date-time" },
        "last_oracle_prediction": { "type": "string", "format": "date-time" },
        "last_hypothesis_batch": { "type": "string", "format": "date-time" },
        "open_hypotheses": { "type": "integer" },
        "prediction_confidence_avg": { "type": "number" }
      }
    },
    "trajectory": {
      "type": "object",
      "description": "Projected system state — what the system expects to be true in the near future",
      "properties": {
        "predicted_phi_30m": { "type": "number" },
        "predicted_phi_6h": { "type": "number" },
        "predicted_phi_24h": { "type": "number" },
        "entropy_current": { "type": "number", "description": "Shannon entropy of recent decision type distribution" },
        "entropy_basin": { "type": "number", "description": "Predicted entropy at next stable basin" },
        "branch_instability": { "type": "number", "description": "0-1 score: how much present state diverges from predicted settlement" },
        "basin_distance": { "type": "number", "description": "Magnitude of current-vs-basin delta — triggers negative latency when >threshold" },
        "trajectory_vector": { "type": "string", "enum": ["ASCENDING", "STABLE", "DESCENDING", "VOLATILE"] }
      }
    },
    "latency_mode": {
      "type": "string",
      "enum": ["NORMAL", "PREDICTIVE", "NEGATIVE_LATENCY"],
      "description": "NEGATIVE_LATENCY: system is acting on future settlement before explicit closure"
    },
    "negative_latency_active": { "type": "boolean" },
    "negative_latency_reason": { "type": "string" },
    "market": {
      "type": "object",
      "properties": {
        "btc_usd": { "type": "number" },
        "btc_24h_change": { "type": "number" },
        "fear_greed": { "type": "integer" },
        "fear_greed_label": { "type": "string" },
        "top_polymarket": { "type": "string" }
      }
    },
    "immune": {
      "type": "object",
      "properties": {
        "threats_last_scan": { "type": "integer" },
        "last_immune_scan": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["CLEAR", "ALERT", "CRITICAL"] }
      }
    },
    "airtable_synced": { "type": "boolean" },
    "airtable_record_id": { "type": "string" },
    "hash": { "type": "string" }
  }
}
